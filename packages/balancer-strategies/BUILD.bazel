LINUX_ONLY = ["@platforms//os:linux"]

cc_library(
    name = "strategy",
    hdrs = ["include/strategy.hpp"],
    strip_include_prefix = "include",
    target_compatible_with = LINUX_ONLY,
    visibility = ["//visibility:public"],
)

# raw file dep for runtime consumers (e.g. llm-strategy's generator compiles
# freshly-generated source against this header).
filegroup(
    name = "strategy_hdr",
    srcs = ["include/strategy.hpp"],
    visibility = ["//visibility:public"],
)

cc_binary(
    name = "libteststrategy.so",
    srcs = ["strategies/test-strategy-impl.cpp"],
    linkshared = True,
    target_compatible_with = LINUX_ONLY,
    visibility = ["//visibility:public"],
    deps = [":strategy"],
)

cc_binary(
    name = "libweightedstrategy.so",
    srcs = ["strategies/weighted-strategy-impl.cpp"],
    linkshared = True,
    target_compatible_with = LINUX_ONLY,
    visibility = ["//visibility:public"],
    deps = [":strategy"],
)

cc_binary(
    name = "test_main",
    srcs = ["test/main.cpp"],
    data = [":libteststrategy.so"],
    linkopts = ["-ldl"],
    target_compatible_with = LINUX_ONLY,
    deps = [":strategy"],
)

cc_binary(
    name = "swap_test_main",
    srcs = ["test/swap_test.cpp"],
    data = [
        ":libteststrategy.so",
        ":libweightedstrategy.so",
    ],
    linkopts = ["-ldl"],
    target_compatible_with = LINUX_ONLY,
    deps = [":strategy"],
)

sh_test(
    name = "swap_test",
    srcs = ["test/run_swap_test.sh"],
    data = [
        ":libteststrategy.so",
        ":libweightedstrategy.so",
        ":swap_test_main",
    ],
    env = {
        "SWAP_TEST_MAIN": "$(rootpath :swap_test_main)",
        "RR_LIB": "$(rootpath :libteststrategy.so)",
        "WEIGHTED_LIB": "$(rootpath :libweightedstrategy.so)",
    },
    tags = ["ci"],
    target_compatible_with = LINUX_ONLY,
)

sh_test(
    name = "strategy_test",
    srcs = ["test/run_test.sh"],
    data = [
        ":libteststrategy.so",
        ":test_main",
    ],
    env = {
        "TEST_MAIN": "$(rootpath :test_main)",
        "STRATEGY_LIB": "$(rootpath :libteststrategy.so)",
    },
    tags = ["ci"],
    target_compatible_with = LINUX_ONLY,
)
